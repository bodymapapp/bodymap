{"ast":null,"code":"import{useState,useEffect}from'react';export function useMobile(){const[isMobile,setIsMobile]=useState(window.innerWidth<768);useEffect(()=>{const handler=()=>setIsMobile(window.innerWidth<768);window.addEventListener('resize',handler);return()=>window.removeEventListener('resize',handler);},[]);return isMobile;}export function useIsPWA(){return window.matchMedia('(display-mode: standalone)').matches||window.navigator.standalone===true;}","map":{"version":3,"names":["useState","useEffect","useMobile","isMobile","setIsMobile","window","innerWidth","handler","addEventListener","removeEventListener","useIsPWA","matchMedia","matches","navigator","standalone"],"sources":["/home/claude/bodymap/src/hooks/useMobile.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport function useMobile() {\n  const [isMobile, setIsMobile] = useState(window.innerWidth < 768);\n  \n  useEffect(() => {\n    const handler = () => setIsMobile(window.innerWidth < 768);\n    window.addEventListener('resize', handler);\n    return () => window.removeEventListener('resize', handler);\n  }, []);\n  \n  return isMobile;\n}\n\nexport function useIsPWA() {\n  return window.matchMedia('(display-mode: standalone)').matches || \n         window.navigator.standalone === true;\n}\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,SAAS,CAAAC,SAASA,CAAA,CAAG,CAC1B,KAAM,CAACC,QAAQ,CAAEC,WAAW,CAAC,CAAGJ,QAAQ,CAACK,MAAM,CAACC,UAAU,CAAG,GAAG,CAAC,CAEjEL,SAAS,CAAC,IAAM,CACd,KAAM,CAAAM,OAAO,CAAGA,CAAA,GAAMH,WAAW,CAACC,MAAM,CAACC,UAAU,CAAG,GAAG,CAAC,CAC1DD,MAAM,CAACG,gBAAgB,CAAC,QAAQ,CAAED,OAAO,CAAC,CAC1C,MAAO,IAAMF,MAAM,CAACI,mBAAmB,CAAC,QAAQ,CAAEF,OAAO,CAAC,CAC5D,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CAAAJ,QAAQ,CACjB,CAEA,MAAO,SAAS,CAAAO,QAAQA,CAAA,CAAG,CACzB,MAAO,CAAAL,MAAM,CAACM,UAAU,CAAC,4BAA4B,CAAC,CAACC,OAAO,EACvDP,MAAM,CAACQ,SAAS,CAACC,UAAU,GAAK,IAAI,CAC7C","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}