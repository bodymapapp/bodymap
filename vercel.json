{
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/s/:code",
      "has": [{ "type": "query", "key": "spa", "value": "1" }],
      "destination": "/index.html"
    },
    {
      "source": "/agreement-sign/:token",
      "has": [{ "type": "query", "key": "spa", "value": "1" }],
      "destination": "/index.html"
    },
    {
      "source": "/s/:code",
      "destination": "/api/agreement-preview?route=s&key=:code"
    },
    {
      "source": "/agreement-sign/:token",
      "destination": "/api/agreement-preview?route=agreement-sign&key=:token"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/og-card-v3.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, must-revalidate" }
      ]
    },
    {
      "source": "/og-card.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, must-revalidate" }
      ]
    }
  ]
}
